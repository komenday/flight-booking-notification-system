{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY_HERE",
    "FromEmail": "noreply@flightbooking.com",
    "FromName": "Flight Booking System"
  },
  "FileLogger": {
    "LogFilePath": "logs/notifications.log"
  },
  "Webhook": {
    "ApiKey": "fbns-secure-key-2024-change-in-production"
  },
  "Cors": {
    "AllowedOrigins": {
      "FBS": "https://localhost:5001"
    }
  },
  "AllowedHosts": "*"
}